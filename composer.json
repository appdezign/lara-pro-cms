{
    "name": "appdezign/lara-pro-cms",
    "description": "Lara Pro CMS",
	"version": "10.6.1",
    "keywords": ["Lara", "CMS"],
    "license": "proprietary",
    "homepage": "https://firmaq.nl",
    "type": "laravel-library",
    "authors": [
        {
            "name": "Sybrand Hoeksma",
            "email": "s.hoeksma@firmaq.nl"
        }
    ],
    "require": {
		"php": "^8.3",
		"appdezign/lara-pro-base-theme": "^10.0",
		"appdezign/lara-pro-demo-theme": "^10.0",
		"arrilot/laravel-widgets": "^3.14",
		"awcodes/filament-curator": "^5.0",
		"awcodes/filament-versions": "^4.0",
		"awcodes/richer-editor": "^2.0",
		"bezhansalleh/filament-google-analytics": "^3.0",
		"binafy/laravel-stub": "^1.1",
		"composer/installers": "^2.0",
		"cviebrock/eloquent-sluggable": "^13.0",
		"davidhsianturi/blade-bootstrap-icons": "^2.1",
		"filament/filament": "^5.6",
		"filament/spatie-laravel-google-fonts-plugin": "^5.0",
		"jeffgreco13/filament-breezy": "^3.0",
		"kalnoy/nestedset": "^7.0",
		"kitloong/laravel-migrations-generator": "^7.2",
		"laracasts/flash": "^3.2",
		"laravel/framework": "^13.0",
		"laravel/helpers": "^1.7",
		"laravel/ui": "^4.6",
		"mcamara/laravel-localization": "^2.3",
		"njxqlus/filament-relation-manager-component": "^2.0",
		"orangehill/iseed": "^3.1",
		"shuvroroy/filament-spatie-laravel-health": "^3.1",
		"spatie/geocoder": "^4.0",
		"spatie/laravel-health": "^1.34",
		"spatie/laravel-honeypot": "^4.6",
		"spatie/laravel-html": "^3.12",
		"spatie/laravel-permission": "^6.20",
		"spatie/laravel-ray": "^1.40",
		"spatie/laravel-responsecache": "^8.3",
		"spatie/security-advisories-health-check": "^1.3",
		"yebor974/filament-renew-password": "^3.0"
	},
	"autoload": {
		"psr-4": {
			"Lara\\Admin\\": "src/admin/",
			"Lara\\Common\\": "src/common/",
			"Lara\\Front\\": "src/front/"
		},
		"files": [
			"src/admin/Helpers/helpers.php",
			"src/common/Helpers/helpers.php",
			"src/front/Helpers/helpers.php"
		]
	},
	"extra": {
		"laravel": {
			"providers": [
				"Lara\\Admin\\Providers\\LaraAdminServiceProvider",
				"Lara\\Common\\Providers\\LaraCommonServiceProvider",
				"Lara\\Front\\Providers\\LaraFrontServiceProvider"
			]
		},
		"installer-paths": {
			"laracms/core": [
				"appdezign/lara-pro-cms"
			],
			"laracms/themes/{$name}": [
				"appdezign/lara-pro-base-theme",
				"appdezign/lara-pro-demo-theme"
			]
		}
	}
}
